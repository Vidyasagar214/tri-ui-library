{
  "name": "tri-ui-library",
  "version": "1.0.3",
  "description": "Reusable React UI component library with plain CSS — no Tailwind, MUI, or Bootstrap",
  "type": "module",
  "license": "MIT",
  "author": "",
  "keywords": [
    "react",
    "react-components",
    "ui",
    "ui-library",
    "design-system",
    "components",
    "css",
    "vite"
  ],
  "main": "./dist/tri-ui-library.umd.cjs",
  "module": "./dist/tri-ui-library.js",
  "exports": {
    ".": {
      "import": "./dist/tri-ui-library.js",
      "require": "./dist/tri-ui-library.umd.cjs",
      "default": "./dist/tri-ui-library.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css",
    "./dist/styles.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Vidyasagar214/tri-ui-library.git"
  },
  "bugs": {
    "url": "https://github.com/Vidyasagar214/tri-ui-library/issues"
  },
  "homepage": "https://tri-ui-library.vercel.app",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js",
    "build": "node ./node_modules/vite/bin/vite.js build",
    "build:site": "node ./node_modules/vite/bin/vite.js build --config vite.config.site.js",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "preview:site": "node ./node_modules/vite/bin/vite.js preview --config vite.config.site.js",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "vite": "^5.4.0",
    "@vitejs/plugin-react": "^4.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
